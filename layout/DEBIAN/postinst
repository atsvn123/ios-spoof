#!/bin/sh

APP_ROOTLESS="/var/jb/Applications/iOSSpoof.app"
APP_VIRTUAL="/Applications/iOSSpoof.app"

for app in "$APP_ROOTLESS" "$APP_VIRTUAL"; do
    if [ -d "$app" ]; then
        chmod 755 "$app" >/dev/null 2>&1 || true
        chmod 755 "$app/iOSSpoof" >/dev/null 2>&1 || true
    fi
done

exit 0

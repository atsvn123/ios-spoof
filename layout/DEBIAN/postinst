#!/bin/sh

APP_PATH="/Applications/iOSSpoof.app"
ROOTLESS_APP_PATH="/var/jb/Applications/iOSSpoof.app"
if [ -d "$ROOTLESS_APP_PATH" ]; then
    APP_PATH="$ROOTLESS_APP_PATH"
fi

# Ensure SpringBoard can discover the app bundle even if dpkg preserves restrictive modes.
chmod 755 "$APP_PATH" >/dev/null 2>&1 || true
chmod 755 "$APP_PATH/iOSSpoofApp" >/dev/null 2>&1 || true

if [ -x "/var/jb/usr/bin/uicache" ]; then
    /var/jb/usr/bin/uicache -p "$APP_PATH" >/dev/null 2>&1 || /var/jb/usr/bin/uicache -a >/dev/null 2>&1 || true
elif [ -x "/usr/bin/uicache" ]; then
    /usr/bin/uicache -p "$APP_PATH" >/dev/null 2>&1 || /usr/bin/uicache -a >/dev/null 2>&1 || true
fi

killall -9 lsd >/dev/null 2>&1 || true

exit 0

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>items</key>
    <array>
        <dict>
            <key>cell</key>
            <string>PSGroupCell</string>
            <key>label</key>
            <string>Target Apps</string>
            <key>footerText</key>
            <string>Nhập bundle ID của app cần spoof, phân tách bằng dấu phẩy. Ví dụ: com.example.app. Để trống = không spoof app nào (an toàn). Cần respring để áp dụng.</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSEditTextCell</string>
            <key>label</key>
            <string>Bundle IDs</string>
            <key>set</key>
            <string>setTargetBundles:forSpecifier:</string>
            <key>get</key>
            <string>readTargetBundles:</string>
            <key>placeholder</key>
            <string>com.example.app1,com.example.app2</string>
        </dict>

        <!-- ===== MASTER ===== -->
        <dict>
            <key>cell</key>
            <string>PSSwitchCell</string>
            <key>label</key>
            <string>Bật Spoofing</string>
            <key>key</key>
            <string>enabled</string>
            <key>set</key>
            <string>setEnabled:forSpecifier:</string>
            <key>get</key>
            <string>readEnabled:</string>
            <key>defaults</key>
            <string>com.iosspoof.tweak</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSGroupCell</string>
            <key>label</key>
            <string>Thiết bị</string>
            <key>footerText</key>
            <string>Chọn preset thiết bị muốn giả lập. Random sẽ chọn ngẫu nhiên mỗi lần respring.</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSLinkListCell</string>
            <key>label</key>
            <string>Model</string>
            <key>set</key>
            <string>setProductType:forSpecifier:</string>
            <key>get</key>
            <string>readProductType:</string>
            <key>valuesDataSource</key>
            <string>readValues:</string>
            <key>titlesDataSource</key>
            <string>readTitlesForSpecifier:</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSSwitchCell</string>

        <!-- ===== PROXY ===== -->
        <dict>
            <key>cell</key><string>PSGroupCell</string>
            <key>label</key><string>Transparent Proxy</string>
            <key>footerText</key>
            <string>Proxy chạy ở network layer qua PF divert. KHÔNG set system proxy nên app không detect được. Cần daemon scproxyd chạy.</string>
